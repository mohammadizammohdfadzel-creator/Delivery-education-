<!DOCTYPE html>
<html lang="ms">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sarawak Edu-Delivery Game</title>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap');

        :root {
            --primary: #8e44ad; /* Purple */
            --primary-light: #b062d1;
            --white: #ffffff;
            --dark: #2c3e50;
            --success: #2ecc71;
            --danger: #e74c3c;
            --bg-color: #f4f6f9;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            font-family: 'Poppins', sans-serif;
        }

        body {
            background-color: var(--bg-color);
            color: var(--dark);
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            overflow: hidden;
            background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
        }

        #game-container {
            width: 100%;
            max-width: 450px;
            height: 90vh;
            background: var(--white);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.2);
            position: relative;
            overflow: hidden;
            display: flex;
            flex-direction: column;
        }

        .screen {
            display: none;
            padding: 20px;
            height: 100%;
            flex-direction: column;
            animation: fadeIn 0.5s ease;
        }

        .screen.active {
            display: flex;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(10px); }
            to { opacity: 1; transform: translateY(0); }
        }

        h1, h2, h3 {
            text-align: center;
            color: var(--primary);
            margin-bottom: 15px;
        }

        p {
            text-align: center;
            margin-bottom: 15px;
            font-size: 14px;
        }

        /* Setup Screen */
        .selection-group {
            margin-bottom: 15px;
            background: #f9f9f9;
            padding: 15px;
            border-radius: 12px;
            border: 2px solid #eaeaea;
        }

        .selection-group label {
            font-weight: 600;
            display: block;
            margin-bottom: 10px;
            text-align: center;
        }

        .options-row {
            display: flex;
            justify-content: space-around;
        }

        .option-btn {
            background: var(--white);
            border: 2px solid #ddd;
            border-radius: 10px;
            padding: 10px 20px;
            cursor: pointer;
            transition: all 0.3s;
            font-weight: 600;
        }

        .option-btn.selected {
            border-color: var(--primary);
            background: #f4e8fd;
            color: var(--primary);
            box-shadow: 0 4px 10px rgba(142, 68, 173, 0.2);
        }

        .file-upload {
            text-align: center;
            margin-top: 10px;
        }
        
        .file-upload input {
            font-size: 12px;
        }

        .btn-main {
            background: var(--primary);
            color: var(--white);
            border: none;
            padding: 15px;
            border-radius: 30px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: auto;
            text-transform: uppercase;
            box-shadow: 0 5px 15px rgba(142, 68, 173, 0.4);
        }

        .btn-main:hover {
            background: var(--primary-light);
            transform: translateY(-2px);
        }

        /* Avatar CSS (No eyes, no nose, purple & white) */
        .avatar-display {
            width: 100px;
            height: 100px;
            margin: 0 auto 10px;
            position: relative;
        }

        .avatar-head {
            width: 60px;
            height: 60px;
            background: #f1c27d;
            border-radius: 50%;
            position: absolute;
            top: 10px;
            left: 20px;
            z-index: 2;
            background-size: cover;
            background-position: center;
            border: 2px solid var(--primary);
        }

        /* The mouth */
        .avatar-mouth {
            width: 20px;
            height: 10px;
            border-bottom: 2px solid #a67c52;
            border-radius: 50%;
            position: absolute;
            bottom: 15px;
            left: 20px;
        }

        .avatar-body {
            width: 80px;
            height: 50px;
            background: linear-gradient(to bottom, var(--white) 30%, var(--primary) 30%);
            border-radius: 20px 20px 0 0;
            position: absolute;
            bottom: 0;
            left: 10px;
            z-index: 1;
            border: 2px solid var(--primary);
        }

        /* Game Screen */
        .header-stats {
            display: flex;
            justify-content: space-between;
            background: var(--primary);
            color: var(--white);
            padding: 15px;
            border-radius: 15px;
            margin-bottom: 20px;
            font-weight: 600;
            box-shadow: 0 4px 10px rgba(0,0,0,0.1);
        }

        .map-area {
            flex-grow: 1;
            background: #a3e4d7;
            border-radius: 15px;
            position: relative;
            margin-bottom: 20px;
            overflow: hidden;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 3px solid #76d7c4;
        }

        .map-bg {
            position: absolute;
            width: 100%;
            height: 100%;
            background-image: radial-gradient(#ffffff 20%, transparent 20%),
            radial-gradient(#ffffff 20%, transparent 20%);
            background-color: #a3e4d7;
            background-position: 0 0, 25px 25px;
            background-size: 50px 50px;
            opacity: 0.3;
        }

        .map-text {
            position: absolute;
            top: 10px;
            left: 10px;
            background: rgba(255,255,255,0.8);
            padding: 5px 10px;
            border-radius: 8px;
            font-size: 12px;
            font-weight: 700;
            z-index: 5;
        }

        .player-sprite {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            font-size: 50px;
            z-index: 10;
            animation: bounce 1s infinite alternate;
        }

        @keyframes bounce {
            from { transform: translateX(-50%) translateY(0); }
            to { transform: translateX(-50%) translateY(-10px); }
        }

        /* Question Screen */
        .subject-badge {
            background: #f1c40f;
            color: var(--dark);
            padding: 5px 15px;
            border-radius: 20px;
            display: inline-block;
            margin: 0 auto 15px;
            font-weight: 700;
            font-size: 12px;
        }

        .question-box {
            background: var(--white);
            padding: 20px;
            border-radius: 15px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.05);
            margin-bottom: 20px;
            font-size: 16px;
            font-weight: 600;
            text-align: center;
            border: 1px solid #eee;
        }

        .answers-grid {
            display: grid;
            grid-template-columns: 1fr;
            gap: 12px;
        }

        .answer-btn {
            background: var(--white);
            border: 2px solid var(--primary);
            color: var(--primary);
            padding: 12px;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s;
        }

        .answer-btn:hover {
            background: var(--primary);
            color: var(--white);
        }

        /* Result Animation */
        .result-icon {
            font-size: 60px;
            text-align: center;
            margin: 20px 0;
        }

        .money-earned {
            font-size: 30px;
            color: var(--success);
            font-weight: 700;
            text-align: center;
            margin-bottom: 20px;
        }
    </style>
</head>
<body>

<div id="game-container">
    
    <!-- SCREEN 1: SETUP -->
    <div id="screen-setup" class="screen active">
        <h1>Delivery Edu-Game</h1>
        <p>Bina watak anda & Mula hantar makanan di Sarawak!</p>

        <div class="avatar-display">
            <div class="avatar-head" id="preview-head">
                <div class="avatar-mouth"></div>
            </div>
            <div class="avatar-body"></div>
        </div>

        <div class="selection-group">
            <label>Pilih Jantina</label>
            <div class="options-row">
                <div class="option-btn selected" onclick="setGender('lelaki', this)">Lelaki</div>
                <div class="option-btn" onclick="setGender('wanita', this)">Wanita</div>
            </div>
            <div class="file-upload">
                <label style="font-size: 11px; margin-top:10px;">Guna Wajah Sendiri (Pilihan):</label>
                <input type="file" id="face-upload" accept="image/*" onchange="uploadFace(event)">
            </div>
        </div>

        <div class="selection-group">
            <label>Pilih Motosikal</label>
            <div class="options-row">
                <div class="option-btn selected" onclick="setBike('🛵', this)" style="font-size: 24px;">🛵</div>
                <div class="option-btn" onclick="setBike('🏍️', this)" style="font-size: 24px;">🏍️</div>
            </div>
        </div>

        <button class="btn-main" onclick="startGame()">Mula Bekerja!</button>
    </div>

    <!-- SCREEN 2: GAME/MAP -->
    <div id="screen-game" class="screen">
        <div class="header-stats">
            <div id="display-earnings">Wang: RM 0.00</div>
            <div id="display-deliveries">Tugas: 0</div>
        </div>
        
        <h2 style="font-size: 18px;">Menunggu Pesanan...</h2>
        
        <div class="map-area">
            <div class="map-bg"></div>
            <div class="map-text" id="location-text">Lokasi: Simunjan, Sarawak</div>
            <div class="player-sprite" id="player-vehicle">🛵</div>
        </div>

        <p id="game-status">Pelanggan sedang mencari rider...</p>
        <button class="btn-main" id="btn-deliver" onclick="startDelivery()">Ambil Pesanan (RM 3.00)</button>
    </div>

    <!-- SCREEN 3: QUESTION -->
    <div id="screen-question" class="screen">
        <h3>Pelanggan Bertanya!</h3>
        <p>Jawab dengan betul untuk dapat <b>TIPS LEBIH</b>.</p>
        
        <div style="text-align: center;">
            <div class="subject-badge" id="q-subject">Subjek</div>
        </div>
        
        <div class="question-box" id="q-text">
            Soalan akan muncul di sini?
        </div>

        <div class="answers-grid" id="q-answers">
            <!-- Butang jawapan dijana menggunakan JS -->
        </div>
    </div>

    <!-- SCREEN 4: RESULT -->
    <div id="screen-result" class="screen">
        <h2 id="result-title">Keputusan</h2>
        <div class="result-icon" id="result-emoji">🎉</div>
        <p id="result-message">Tahniah! Jawapan tepat.</p>
        <div class="money-earned" id="result-money">+ RM 5.00 Tips!</div>
        
        <button class="btn-main" onclick="backToMap()">Teruskan Menghantar</button>
    </div>

</div>

<script>
    // --- GAME STATE ---
    let earnings = 0.0;
    let deliveries = 0;
    let selectedGender = 'lelaki';
    let selectedBike = '🛵';
    let faceDataUrl = null;
    let currentQuestion = null;

    // --- DATA SOALAN ---
    const questionsDatabase = [
        // Matematik
        { subject: 'Matematik', q: 'Berapakah jumlah 45 + 55?', options: ['90', '100', '110', '120'], answer: 1 },
        { subject: 'Matematik', q: 'Jika 1 kg epal harga RM8, berapakah harga 3 kg?', options: ['RM16', 'RM20', 'RM24', 'RM30'], answer: 2 },
        // Sains
        { subject: 'Sains', q: 'Apakah gas yang diperlukan oleh manusia untuk bernafas?', options: ['Karbon Dioksida', 'Oksigen', 'Nitrogen', 'Helium'], answer: 1 },
        { subject: 'Sains', q: 'Pusat sistem suria kita ialah...', options: ['Bumi', 'Bulan', 'Matahari', 'Marikh'], answer: 2 },
        // Bahasa Malaysia
        { subject: 'Bahasa Malaysia', q: 'Pilih ejaan yang betul.', options: ['Motosikal', 'Motorsikal', 'Motosikal', 'Motorsikal'], answer: 0 },
        { subject: 'Bahasa Malaysia', q: 'Lengkapkan peribahasa: Sediakan payung sebelum...', options: ['Mandi', 'Hujan', 'Panas', 'Kering'], answer: 1 },
        // Bahasa English
        { subject: 'Bahasa English', q: 'Choose the correct past tense of "Run".', options: ['Runned', 'Ran', 'Running', 'Rans'], answer: 1 },
        { subject: 'Bahasa English', q: 'The cat is sleeping ___ the table.', options: ['under', 'between', 'through', 'into'], answer: 0 },
        // Sejarah
        { subject: 'Sejarah', q: 'Siapakah "Rajah Putih" pertama yang memerintah Sarawak?', options: ['Charles Brooke', 'James Brooke', 'Vyner Brooke', 'Rentap'], answer: 1 },
        { subject: 'Sejarah', q: 'Sarawak bersama Tanah Melayu, Sabah dan Singapura membentuk Malaysia pada tahun...', options: ['1957', '1963', '1965', '1969'], answer: 1 }
    ];

    const locationsSarawak = [
        "Simunjan, Sarawak", 
        "Kuching, Sarawak", 
        "Miri, Sarawak", 
        "Bintulu, Sarawak", 
        "Sibu, Sarawak", 
        "Kota Samarahan, Sarawak",
        "Mukah, Sarawak"
    ];

    // --- FUNCTIONS SETUP ---
    function setGender(gender, element) {
        selectedGender = gender;
        let siblings = element.parentElement.children;
        for(let el of siblings) el.classList.remove('selected');
        element.classList.add('selected');
    }

    function setBike(bike, element) {
        selectedBike = bike;
        let siblings = element.parentElement.children;
        for(let el of siblings) el.classList.remove('selected');
        element.classList.add('selected');
    }

    function uploadFace(event) {
        const file = event.target.files[0];
        if(file) {
            const reader = new FileReader();
            reader.onload = function(e) {
                faceDataUrl = e.target.result;
                document.getElementById('preview-head').style.backgroundImage = `url(${faceDataUrl})`;
            }
            reader.readAsDataURL(file);
        }
    }

    // --- FUNCTIONS GAME FLOW ---
    function switchScreen(screenId) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(screenId).classList.add('active');
    }

    function updateStats() {
        document.getElementById('display-earnings').innerText = `Wang: RM ${earnings.toFixed(2)}`;
        document.getElementById('display-deliveries').innerText = `Tugas: ${deliveries}`;
    }

    function startGame() {
        document.getElementById('player-vehicle').innerText = selectedBike;
        updateStats();
        switchScreen('screen-game');
    }

    function startDelivery() {
        // Change Location Randomly
        const randomLoc = locationsSarawak[Math.floor(Math.random() * locationsSarawak.length)];
        document.getElementById('location-text').innerText = `Lokasi: ${randomLoc}`;
        
        document.getElementById('btn-deliver').style.display = 'none';
        document.getElementById('game-status').innerText = "Sedang menunggang ke rumah pelanggan...";
        
        // Simulate driving time
        setTimeout(() => {
            triggerQuestion();
        }, 2000);
    }

    function triggerQuestion() {
        // Base Delivery Fee earned!
        earnings += 3.00; 
        deliveries += 1;
        
        // Pick random question
        currentQuestion = questionsDatabase[Math.floor(Math.random() * questionsDatabase.length)];
        
        document.getElementById('q-subject').innerText = currentQuestion.subject;
        document.getElementById('q-text').innerText = currentQuestion.q;
        
        const ansContainer = document.getElementById('q-answers');
        ansContainer.innerHTML = ''; // clear old
        
        currentQuestion.options.forEach((opt, index) => {
            const btn = document.createElement('button');
            btn.className = 'answer-btn';
            btn.innerText = opt;
            btn.onclick = () => checkAnswer(index);
            ansContainer.appendChild(btn);
        });

        switchScreen('screen-question');
    }

    function checkAnswer(selectedIndex) {
        let isCorrect = (selectedIndex === currentQuestion.answer);
        
        if (isCorrect) {
            earnings += 5.00; // Tips for correct answer
            document.getElementById('result-title').innerText = "Tepat Sekali!";
            document.getElementById('result-emoji').innerText = "🌟";
            document.getElementById('result-message').innerText = "Pelanggan kagum dengan kebijaksanaan anda!";
            document.getElementById('result-money').innerText = "Bayaran RM 3.00 + Tips RM 5.00!";
            document.getElementById('result-money').style.color = "var(--success)";
        } else {
            document.getElementById('result-title').innerText = "Salah!";
            document.getElementById('result-emoji').innerText = "😅";
            document.getElementById('result-message').innerText = "Pelanggan senyum sahaja. Teruskan belajar!";
            document.getElementById('result-money').innerText = "Bayaran RM 3.00 (Tiada Tips)";
            document.getElementById('result-money').style.color = "var(--danger)";
        }
        
        updateStats();
        switchScreen('screen-result');
    }

    function backToMap() {
        document.getElementById('btn-deliver').style.display = 'block';
        document.getElementById('game-status').innerText = "Pelanggan baru sedang dicari...";
        switchScreen('screen-game');
    }
</script>

</body>
</html>

